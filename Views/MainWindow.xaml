<Window x:Class="SecureNotesWin.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SecureNotesWin.Views"
        xmlns:loc="clr-namespace:SecureNotesWin.Localization"
        Title="Secure Notes" Height="700" Width="1100" MinHeight="500" MinWidth="800"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:BodyPreviewConverter          x:Key="BodyPreview"/>
        <views:ColorStringToBrushConverter   x:Key="ColorToBrush"/>
        <views:UnixMsToDateTimeConverter     x:Key="UnixMsToDate"/>
        <views:EmojiImageConverter           x:Key="EmojiImage"/>
    </Window.Resources>

    <Grid>
        <!-- Lock Screen -->
        <views:LockScreenView x:Name="LockScreenPanel" Visibility="Collapsed" Panel.ZIndex="100"/>

        <!-- Main layout -->
        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ SIDEBAR ══ -->
            <Grid Grid.Column="0" Background="{DynamicResource SidebarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App header -->
                <StackPanel Grid.Row="0" Margin="16,20,16,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#C87A0A" Offset="0"/>
                                    <GradientStop Color="#7A4E00" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                            <Image Source="/Assets/LockIcon_32.png" Width="20" Height="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{loc:Loc secure_notes}" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource SidebarTextBrush}"/>
                            <TextBlock x:Name="VaultPathLabel" FontSize="10" Foreground="#606060"
                                       TextTrimming="CharacterEllipsis" MaxWidth="158"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,0">

                        <!-- BOOKS header -->
                        <Grid Margin="14,6,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Loc books}" FontSize="10" FontWeight="Bold"
                                       Foreground="#606060" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+" ToolTip="{loc:Loc add_book}"
                                    Width="22" Height="22" Background="Transparent"
                                    BorderThickness="0" Foreground="#888888"
                                    FontSize="18" FontWeight="Bold" Cursor="Hand" Padding="0"
                                    Click="BtnAddBook_Click"/>
                        </Grid>

                        <!-- Notebook items -->
                        <ItemsControl x:Name="NotebookList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Button Tag="{Binding}" Click="NotebookItem_Click"
                                                Style="{DynamicResource SidebarButtonStyle}">
                                            <DockPanel>
                                                <Image Source="{Binding Icon, Converter={StaticResource EmojiImage}, ConverterParameter=18}"
                                                       Width="18" Height="18"
                                                       Margin="0,0,8,0"
                                                       DockPanel.Dock="Left"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                        </Button>
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{loc:Loc rename}" Tag="{Binding}"
                                                          Click="NotebookRename_Click"/>
                                                <MenuItem Header="{loc:Loc delete}" Tag="{Binding}"
                                                          Click="NotebookDelete_Click"
                                                          Foreground="#EF4444"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Rectangle Height="1" Fill="#1E1E1E" Margin="14,8,14,6"/>

                        <!-- TAGS header -->
                        <Grid Margin="14,4,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TAGS" FontSize="10" FontWeight="Bold"
                                       Foreground="#606060" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+" ToolTip="Add Tag"
                                    Width="22" Height="22" Background="Transparent"
                                    BorderThickness="0" Foreground="#888888"
                                    FontSize="18" FontWeight="Bold" Cursor="Hand" Padding="0"
                                    Click="BtnAddTag_Click"/>
                        </Grid>

                        <ItemsControl x:Name="TagList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Button Tag="{Binding}" Click="TagItem_Click"
                                                Style="{DynamicResource SidebarButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="# " Margin="0,0,4,0"
                                                           Foreground="{Binding Color, Converter={StaticResource ColorToBrush}}"/>
                                                <TextBlock Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{Binding Color, Converter={StaticResource ColorToBrush}}"/>
                                            </StackPanel>
                                        </Button>
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{loc:Loc delete}" Tag="{Binding}"
                                                          Click="TagDelete_Click"
                                                          Foreground="#EF4444"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom actions -->
                <StackPanel Grid.Row="2" Margin="8,8">
                    <Rectangle Height="1" Fill="#1E1E1E" Margin="6,0,6,6"/>
                    <Button Style="{DynamicResource SidebarButtonStyle}" Click="BtnSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Margin="0,0,8,0" Foreground="#888888"/>
                            <TextBlock Text="{loc:Loc settings}" Foreground="#C0C0C0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource SidebarButtonStyle}" Click="BtnLock_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/LockIcon_32.png" Width="16" Height="16" Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{loc:Loc lock_vault}" Foreground="#C0C0C0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Column="1" Fill="#1A1A1A"/>

            <!-- ══ NOTES LIST ══ -->
            <Grid Grid.Column="2" Background="{DynamicResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search box -->
                    <Grid Grid.Column="0" Margin="10,2,10,6">

                        <TextBox x:Name="SearchBox"
             Style="{DynamicResource ModernTextBox}"
             Padding="10,6"
             TextChanged="SearchBox_TextChanged"/>

                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[search_notes]}"
               Margin="14,0,0,0"
               VerticalAlignment="Center"
               Foreground="#888"
               IsHitTestVisible="False">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">

                                    <!-- Default hidden -->
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>

                                        <!-- Show only when empty AND not focused -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>

                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>

                                    </Style.Triggers>

                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                    </Grid>

                    <!-- Add note -->
                    <Button Grid.Column="1" x:Name="BtnNewNote" Content="+"
                           ToolTip="{loc:Loc new_note}" Width="32" Height="32" Margin="4,6"
                           Cursor="Hand" FontSize="20" FontWeight="Bold"
                           Foreground="#0A0A0A" Click="BtnNewNote_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="16">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#D4920A" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" Margin="0,0,0,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>


                <!-- Note count -->
                <TextBlock Grid.Row="1" x:Name="NoteCountLabel"
                           FontSize="11" Foreground="#505050"
                           Margin="14,0,0,4"/>

                <!-- Notes list -->
                <ListBox Grid.Row="2" x:Name="NotesList"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="NotesList_SelectionChanged"
                         Padding="8,0,8,8">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}"  CornerRadius="10"
                                    Margin="0,0,0,8" Padding="14,12"
                                    BorderBrush="#242424" BorderThickness="1">
                                <Grid>
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{loc:Loc add_tags}" Tag="{Binding}"
                                                      Click="NoteAddTags_Click"/>
                                            <MenuItem Header="{loc:Loc move_to_notebook}" Tag="{Binding}"
                                                      Click="NoteMoveToNotebook_Click"/>
                                            <MenuItem Header="{loc:Loc move_to_diary}" Tag="{Binding}"
                                                      Click="NoteMoveToDiary_Click"/>
                                            <Separator/>
                                            <MenuItem Header="{loc:Loc delete}" Tag="{Binding}"
                                                      Click="NoteDelete_Click"
                                                      Foreground="#EF4444"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Title row -->
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>

                                    <!-- Body preview -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Body, Converter={StaticResource BodyPreview}}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="32" TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>

                                    <!-- Tag chips row -->
                                    <WrapPanel Grid.Row="2" x:Name="NoteCardTagsPanel"
                                               Margin="0,6,0,0"
                                               Loaded="NoteCardTagsPanel_Loaded"
                                               Tag="{Binding}"/>

                                    <!-- Date -->
                                    <TextBlock Grid.Row="3" FontSize="10"
                                               Foreground="#505050" Margin="0,4,0,0"
                                               Text="{Binding UpdatedAt, Converter={StaticResource UnixMsToDate}, ConverterParameter=long}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Rectangle Grid.Column="3" Fill="#1A1A1A"/>

            <!-- ══ NOTE EDITOR ══ -->
            <Grid Grid.Column="4" Background="{DynamicResource SurfaceBrush}">
                <views:NoteEditorView x:Name="NoteEditor"/>
            </Grid>
        </Grid>
    </Grid>
</Window>