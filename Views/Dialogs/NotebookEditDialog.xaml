<Window x:Class="SecureNotesWin.Views.Dialogs.NotebookEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Notebook" Height="480" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderLabel" Grid.Row="0" Text="Edit Notebook"
                   FontSize="19" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock x:Name="NameLabel" Text="Name" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="TitleBox" Style="{DynamicResource ModernTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock x:Name="IconLabel" Text="Icon" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                    CornerRadius="8" Background="#141414" Padding="6" MaxHeight="160">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="IconPickerPanel"/>
                </ScrollViewer>
            </Border>









            <!--<TextBox x:Name="IconBox" Style="{DynamicResource ModernTextBox}"
                     MaxLength="4" Width="72" HorizontalAlignment="Left"
                     FontSize="18" TextAlignment="Center" Margin="0,8,0,0"/>-->
        </StackPanel>



        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left side -->
            <TextBox Grid.Column="0"
             x:Name="IconBox"
             Style="{DynamicResource ModernTextBox}"
             MaxLength="4"
             Width="82"
             HorizontalAlignment="Left"
             FontSize="14"
             TextAlignment="Center" Padding ="0,0,0,0" />

            <!-- Right side buttons -->
            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                <Button Content="Cancel"
                Padding="18,8"
                Margin="0,0,10,0"
                Style="{DynamicResource SecondaryButtonStyle}"
                Foreground="{DynamicResource TextSecondaryBrush}"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="13"
                Click="BtnCancel_Click" Name="BtnCancel">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Save"
                Style="{DynamicResource PrimaryButtonStyle}"
                Padding="18,8"
                Click="BtnSave_Click" Name="BtnSave"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
