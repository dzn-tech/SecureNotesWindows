<Window x:Class="SecureNotesWin.Views.Dialogs.TagsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Tags" Height="400" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: heading -->
            <RowDefinition Height="*"/>     <!-- 1: tag list -->
            <RowDefinition Height="Auto"/>  <!-- 2: new tag input + Add -->
            <RowDefinition Height="Auto"/>  <!-- 3: color palette row + Done -->
        </Grid.RowDefinitions>

        <!-- Heading -->
        <TextBlock x:Name="HeaderLabel" Grid.Row="0" Text="Manage Tags"
                   FontSize="19" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- Existing tags -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="TagsPanel"/>
        </ScrollViewer>

        <!-- Tag input -->
        <TextBox Grid.Row="2"
         x:Name="NewTagBox"
         Style="{DynamicResource ModernTextBox}"
         Tag="New tag name…"
         VerticalAlignment="Center"
         Margin="0,14,0,0"
         HorizontalAlignment="Stretch"/>

        <!-- Bottom row -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Palette container -->
            <Border Grid.Column="0"
            VerticalAlignment="Center">
                <StackPanel x:Name="ColorPalette"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"/>
            </Border>

            <!-- Add button -->
            <Button x:Name="BtnAddTag" Grid.Column="1"
            Content="Add"
            Style="{DynamicResource PrimaryButtonStyle}"
            Margin="10,0,0,0"
            Padding="14,7"
            VerticalAlignment="Center"
            Click="BtnAddTag_Click"/>
        </Grid>
    </Grid>
</Window>
