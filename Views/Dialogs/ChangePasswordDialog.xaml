<Window x:Class="SecureNotesWin.Views.Dialogs.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password" Height="460" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Change Master Password"
                       FontSize="19" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,24" Name ="ChangeMasterPassword"/>

            <TextBlock Text="Current password" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" Name="CurrentPassword"/>
            <PasswordBox x:Name="OldPwdBox" Style="{DynamicResource ModernPasswordBox}"
                         Margin="0,0,0,16"/>

            <TextBlock Text="New password" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" Name="NewPassword2"/>
            <PasswordBox x:Name="NewPwdBox" Style="{DynamicResource ModernPasswordBox}"
                         Margin="0,0,0,16"/>

            <TextBlock Text="Confirm new password" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" Name="ConfirmNewPassword"/>
            <PasswordBox x:Name="ConfirmPwdBox" Style="{DynamicResource ModernPasswordBox}"
                         Margin="0,0,0,6"/>

            <TextBlock x:Name="ErrorLabel" Foreground="#EF4444" FontSize="12"
                       Visibility="Collapsed" Margin="0,4,0,0" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="Cancel" Padding="18,8" Margin="0,0,10,0"
                    Style="{DynamicResource SecondaryButtonStyle}"
Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0" Cursor="Hand" FontSize="13"
                        Click="BtnCancel_Click" Name="BtnCancel">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Change" Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="18,8" Click="BtnChange_Click" Name="BtnChange"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
