<Window x:Class="SecureNotesWin.Views.Dialogs.PasswordPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Password" Height="210" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <StackPanel Margin="28">
        <TextBlock x:Name="MessageLabel" FontSize="14"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>
        <PasswordBox x:Name="PwdBox" Style="{DynamicResource ModernPasswordBox}"
                     KeyDown="PwdBox_KeyDown"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Cancel" Padding="18,8" Margin="0,0,10,0"
                    Style="{DynamicResource SecondaryButtonStyle}"
Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderThickness="0" Cursor="Hand" FontSize="13"
                    Click="BtnCancel_Click" Name="BtnCancel">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="OK" Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="18,8" Click="BtnOk_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
