<Window x:Class="SecureNotesWin.Views.Dialogs.AddTagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Tag" Height="200" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="New tag" FontSize="17" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14"/>
        <TextBox x:Name="TagNameBox" Style="{DynamicResource ModernTextBox}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderThickness="0" Click="BtnCancel_Click" Name="BtnCancel"/>
            <Button Content="Add" Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="16,8" Click="BtnAdd_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
